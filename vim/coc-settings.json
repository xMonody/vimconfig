    "diagnostic.errorSign": "пҒ—",
    "diagnostic.warningSign": "пҒӘ",
    "diagnostic.infoSign": "пҒҡ",
    "diagnostic.hintSign": "у°  ",
    "diagnostic.virtualTextPrefix": "в—Ҹ",

    //"diagnostic.enable": false,
    "diagnostic.enableMessage": "never",
    "diagnostic.refreshOnInsertMode": false,
    "diagnostic.checkCurrentLine": false,
    "diagnostic.virtualTextLimitInOneLine": 1,

    "diagnostic.virtualText": false,//дҪҝз”ЁиҷҡжӢҹиЎҢиҜҠж–ӯ
    "diagnostic.virtualTextAlign": "after",//дҪҚзҪ®
    "diagnostic.virtualTextCurrentLineOnly": false,
    "signature.preferShownAbove": true,//е°ҪеҸҜиғҪеңЁе…үж ҮдёҠжҳҫзӨәеҮҪж•°зӯҫеҗҚ
    "suggest.virtualText": false,
    //"suggest.noselect": true,
    "suggest.selection": "first",

    "notification.disabledProgressSources": ["*"],//зҰҒз”ЁйҖҡзҹҘ

    "diagnostic.messageTarget": "float",//иҜҠж–ӯ
    "suggest.enableFloat": false,//ж–ҮжЎЈ
    "hover.target": "float",//жӮ¬еҒң
    "colors.enable": true,

    "outline.autoPreview": true,
    "outline.previewBorderRounded": true,
    "outline.keepWindow": true,

    "semanticTokens.enable": true,//иҜӯд№үд»ӨзүҢ
    "suggest.labelMaxLength": 40,

    "diagnostic.floatConfig":{"border":true,"rounded":true,"highlight":"suFloat","borderhighlight":"mmFloat"},
    "suggest.floatConfig":{"border":true,"rounded":true,"highlight":"nnFloat","borderhighlight":"mmFloat"},
    "signature.floatConfig":{"border": true,"rounded": true,"highlight":"snFloat","borderhighlight":"mmFloat"},
    "hover.floatConfig": {"border": true,"rounded": true,"highlight":"suFloat","borderhighlight":"mmFloat"},

    "dialog.floatHighlight": "NONE",
    "dialog.rounded":true,
    "dialog.floatBorderHighlight":"NONE",

    "snippets.priority": 100,//дјҳе…Ҳзә§
    "coc.source.buffer.priority": 80,
    "coc.source.around.priority": 90,
    "inlayHint.enable": false,//е…ій—ӯеҶ…еөҢжҸҗзӨә

    //lua
    "Lua.completion.callSnippet":"Replace",//еҗҜз”ЁеҮҪж•°жҸҗзӨә
    "Lua.signatureHelp.enable": false,//зҰҒз”ЁеҮҪж•°зӯҫеҗҚ
    "sumneko-lua.enableNvimLuaDev":true,
    "sumneko-lua.checkUpdate":false,


    "go.goplsOptions": {
        "completeUnimported": true,
        "usePlaceholders": true,
        "semanticTokens": true
    },

    "languageserver": {
        "glsl": {
            "command": "glsl_analyzer",
            "filetypes": ["glsl", "vert", "tecs", "tese", "frag", "geom", "comp", "vs", "fs"]
        }
    },

    "clangd.arguments": ["--header-insertion=never"],

    //rust
    "rust-analyzer.server.path": "rust-analyzer",//
    "rust-analyzer.disableProgressNotifications":true,

    
    "snippets.textmateSnippetsRoots": ["~/vimconfig/mysnip/snippets"],
    //"snippets.textmateSnippetsRoots": ["D:/vimconfig/mysnip/snippets"],
    
    "suggest.formatItems": [
        "kind",
        "abbr",
        "menu",
        "shortcut"
    ],
    //"coc.source.around.enable": true,
    "coc.source.buffer.shortcut": "Bf",
    "coc.source.around.shortcut": "Ag",
    "coc.source.file.shortcut": "Fi",
    "snippets.shortcut": "Sp",
    "snippets.ultisnips.pythonPrompt": false

}

