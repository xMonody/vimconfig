.wslconfig
# .host:/ /mnt/hgfs fuse.vmhgfs-fuse allow_other,defaults,uid=1000,gid=1000,umask=022 0 0 #挂载共享文件夹

[wsl2]
# kernel=D:\\Wsl\\bzImage
guiApplications = false
vmIdleTimeout = -1
memory = 5G
swap = 10G
networkingMode = mirrored
autoProxy = true

[experimental]
hostAddressLoopback = true
autoMemoryReclaim = dropcache

/etc/wsl.conf

[interop]
enabled = true
appendWindowsPath = false

[boot]
systemd = true

#[user] #默认启动用户名
#default = user_name
